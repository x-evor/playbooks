{% set sync = k3s_platform_values.components.sharedTlsSecretSync %}
apiVersion: v1
kind: ServiceAccount
metadata:
  name: {{ sync.name }}
  namespace: {{ k3s_platform_values.namespaces.platform }}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: {{ sync.name }}-source
  namespace: {{ sync.sourceNamespace }}
rules:
  - apiGroups: [""]
    resources: ["secrets"]
    resourceNames: ["{{ sync.sourceSecretName }}"]
    verbs: ["get", "list", "watch"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: {{ sync.name }}-target
  namespace: {{ sync.targetNamespace }}
rules:
  - apiGroups: [""]
    resources: ["secrets"]
    resourceNames: ["{{ sync.targetSecretName }}"]
    verbs: ["get", "create", "update", "patch"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: {{ sync.name }}-source
  namespace: {{ sync.sourceNamespace }}
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: Role
  name: {{ sync.name }}-source
subjects:
  - kind: ServiceAccount
    name: {{ sync.name }}
    namespace: {{ k3s_platform_values.namespaces.platform }}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: {{ sync.name }}-target
  namespace: {{ sync.targetNamespace }}
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: Role
  name: {{ sync.name }}-target
subjects:
  - kind: ServiceAccount
    name: {{ sync.name }}
    namespace: {{ k3s_platform_values.namespaces.platform }}
---
apiVersion: batch/v1
kind: CronJob
metadata:
  name: {{ sync.name }}
  namespace: {{ k3s_platform_values.namespaces.platform }}
spec:
  schedule: {{ sync.refreshSchedule | to_json }}
  concurrencyPolicy: Forbid
  jobTemplate:
    spec:
      template:
        spec:
          serviceAccountName: {{ sync.name }}
          restartPolicy: OnFailure
          containers:
            - name: sync
              image: bitnami/kubectl:1.30
              command:
                - /bin/sh
                - -ec
                - |
                  kubectl -n {{ sync.sourceNamespace }} get secret {{ sync.sourceSecretName }} -o yaml \
                    | sed '/^  resourceVersion:/d;/^  uid:/d;/^  creationTimestamp:/d;/^  managedFields:/d;/^  annotations:/d;/^  ownerReferences:/d;/^  namespace:/d;/^  selfLink:/d' \
                    | kubectl -n {{ sync.targetNamespace }} apply -f -
