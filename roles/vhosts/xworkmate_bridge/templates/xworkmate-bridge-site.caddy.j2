{{ xworkmate_bridge_domain }} {
{% if (xworkmate_bridge_effective_review_auth_token | default(xworkmate_bridge_review_auth_token) | trim | length) > 0 %}
    @unauthorized expression `{http.request.header.Authorization} != "Bearer {{ xworkmate_bridge_effective_auth_token | default(xworkmate_bridge_auth_token) }}" && {http.request.header.Authorization} != "Bearer {{ xworkmate_bridge_effective_review_auth_token | default(xworkmate_bridge_review_auth_token) }}"`
{% else %}
    @unauthorized {
        not header Authorization "Bearer {{ xworkmate_bridge_effective_auth_token | default(xworkmate_bridge_auth_token) }}"
    }
{% endif %}
    handle @unauthorized {
        header Content-Type "application/json"
        respond `{"jsonrpc":"2.0","error":{"code":-32001,"message":"unauthorized"},"type":"res","ok":false}` 401
    }

    handle /api* {
        reverse_proxy {{ xworkmate_bridge_listen_host }}:{{ xworkmate_bridge_listen_port }}
    }

    handle /artifacts/* {
        reverse_proxy {{ xworkmate_bridge_listen_host }}:{{ xworkmate_bridge_listen_port }}
    }

    handle /acp* {
        reverse_proxy {{ xworkmate_bridge_listen_host }}:{{ xworkmate_bridge_listen_port }} {
            flush_interval -1
            transport http {
                dial_timeout 10s
                read_timeout 30m
                write_timeout 30m
                keepalive 5m
            }
        }
    }

    handle / {
        reverse_proxy {{ xworkmate_bridge_listen_host }}:{{ xworkmate_bridge_listen_port }}
    }

    log {
        output file /var/log/caddy/xworkmate-bridge.log
    }
}
