# XWorkmate Bridge Runtime Configuration
# Generated by Ansible - DO NOT EDIT MANUALLY

# Upstream provider endpoints
# Priority: YAML > Environment Variable > Default Constants
upstream:
  gateway_url: "{{ xworkmate_bridge_openclaw_url }}"
  codex_url: "{{ xworkmate_bridge_codex_rpc_url }}"
  opencode_url: "{{ xworkmate_bridge_opencode_rpc_url }}"
  gemini_url: "{{ xworkmate_bridge_gemini_rpc_url }}"
  hermes_url: "{{ xworkmate_bridge_hermes_rpc_url }}"

# Server orchestration settings
bridge:
  listenAddr: "{{ xworkmate_bridge_listen_addr }}"
  allowedOrigins:
    - "https://{{ xworkmate_bridge_domain | default('xworkmate-bridge.svc.plus') }}"
    - "http://localhost:*"
    - "http://127.0.0.1:*"

# Operational notes for this deployment
notes:
  - Bridge Auth Token is managed via BRIDGE_AUTH_TOKEN environment variable.
  - Deployed on: {{ ansible_date_time.iso8601 | default('N/A') }}
