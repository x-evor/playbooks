services:
  bridge:
    image: "{{ service_compose_image }}"
    container_name: {{ xworkmate_bridge_container_name }}
    restart: unless-stopped
    environment:
{% for env_key, env_value in xworkmate_bridge_container_env.items() %}
      {{ env_key }}: "{{ env_value }}"
{% endfor %}
    ports:
      - "127.0.0.1:{{ xworkmate_bridge_listen_port }}:{{ xworkmate_bridge_container_port }}"
    volumes:
      - /var/log/xworkmate-bridge:/app/logs
    logging:
      driver: "json-file"
      options:
        max-size: "50m"
        max-file: "3"
