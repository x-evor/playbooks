apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{ vllm_service_name }}-ingress
  namespace: {{ vllm_namespace }}
spec:
  rules:
  - host: {{ vllm_ingress_host }}
    http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: {{ vllm_service_name }}
            port:
              number: {{ vllm_port }}
